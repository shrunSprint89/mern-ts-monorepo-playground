{
  "name": "mern-ts-monorepo-playground",
  "version": "1.0.0",
  "description": "[Edit in StackBlitz next generation editor ⚡️](https://stackblitz.com/~/github.com/shrunSprint89/mern-ts-monorepo-playground)",
  "private": true,
  "workspaces": ["client", "server"],  
  "devDependencies": {
    "typescript": "^5.6.2",
    "@types/node": "^22.7.4",
    "concurrently": "^9.1.2"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm start -w client\"",
    "server": "npm run dev --workspace server",
    "client": "npm start --workspace client",
    "build": "npm run build -w server && npm run build -w client",
    "type-check": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
